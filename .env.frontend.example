## Frontend (Vite) environment variables
## Copy to `./.env.local` (or set in your host) when needed.
##
## - For local dev, you can usually omit this because the app defaults to `http://localhost:8000`
## - In production, set this to your deployed backend base URL (no trailing slash)

VITE_API_URL=http://localhost:8000

# Google Maps Places Autocomplete (frontend)
# IMPORTANT: restrict this key in Google Cloud Console to your allowed HTTP referrers.
VITE_GOOGLE_MAPS_API_KEY=AIzaSyBkhqoQrsl48JW7EwXcV8qv2JLCzWgXqG4

